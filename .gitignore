# Secrets / env
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Next.js
node_modules/
.next/
out/
dist/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*

# SQLite (time-series store — runtime data, not source)
*.db
*.sqlite
*.sqlite3
backend/store/*.db-wal
backend/store/*.db-shm

# md+git store — backend/data/ is its OWN git repo (runtime markdown), not source.
# Track the scaffold .gitkeep markers but ignore generated content + the nested repo.
backend/data/.git/
backend/data/projects/*
backend/data/notes/*
backend/data/journal/*
!backend/data/**/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.swp

# Agent memory (per-agent working memory, not source)
.claude/agent-memory/
frontend/.claude/
