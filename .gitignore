# Secrets / env
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Next.js
node_modules/
.next/
out/
dist/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*

# SQLite (time-series store — runtime data, not source)
*.db
*.sqlite
*.sqlite3
backend/store/*.db-wal
backend/store/*.db-shm

# md+git store — backend/data/ is its OWN git repo (runtime markdown), not source.
# Ignore the entire runtime tree (incl. the nested repo) but keep scaffold .gitkeep markers.
backend/data/*
!backend/data/**/.gitkeep

# Scheduler runtime artifact (APScheduler lock) — not source.
.claude/scheduled_tasks.lock

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.swp

# Agent memory (per-agent working memory, not source)
.claude/agent-memory/
**/.claude/agent-memory/
frontend/.claude/
backend/.claude/

# Process / know-how — not public
CLAUDE.md
.claude/
sprints/
