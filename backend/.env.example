# life-os backend — environment template.
#
# Copy to `.env` and fill in. `.env` is gitignored (never commit real secrets);
# `.env.example` is the committed template (placeholder values only).
# All keys use the `LIFEOS_` prefix (pydantic env_prefix). Every value here is
# OPTIONAL — the app runs with the in-code defaults if a key is unset. List/dict
# values are JSON.

# --- OKX exchange (read-only API key, OPTIONAL) -------------------------------
# Leave empty to disable the exchange module (it returns stub/empty data).
# These are SECRETS — keep them only in the local `.env`, never commit them.
LIFEOS_OKX_API_KEY=
LIFEOS_OKX_API_SECRET=
LIFEOS_OKX_API_PASSPHRASE=

# --- Paths (OPTIONAL — default to in-repo locations) --------------------------
# LIFEOS_DATA_DIR=/abs/path/to/data            # md-store git repo (note files)
# LIFEOS_DB_PATH=/abs/path/to/store/life_os.db # SQLite time-series store

# --- External project repos (OPTIONAL, JSON dict id->abs path) ----------------
# LIFEOS_PROJECT_REPOS={"myproj": "/abs/path/to/repo"}

# --- Market (OPTIONAL) --------------------------------------------------------
# LIFEOS_COINGECKO_BASE=https://api.coingecko.com/api/v3
# LIFEOS_MARKET_ASSETS=[{"symbol":"BTC","name":"Bitcoin","assetClass":"crypto","cgId":"bitcoin"}]

# --- Claude usage source paths (OPTIONAL — default ~/.claude/...) -------------
# LIFEOS_CLAUDE_STATS_PATH=/abs/path/stats-cache.json
# LIFEOS_CLAUDE_QUOTA_PATH=/abs/path/quota-snapshot.json
# LIFEOS_CLAUDE_PROJECTS_DIR=/abs/path/.claude/projects
# LIFEOS_CLAUDE_USAGE_CAP=200000

# --- Wiki tuning (OPTIONAL) ---------------------------------------------------
# LIFEOS_WIKI_COLD_START_MIN_NOTES=5
# LIFEOS_WIKI_CLUSTER_MIN_SIZE=3
# LIFEOS_WIKI_CLUSTER_MIN_DENSITY=0.30

# --- App / scheduler / CORS (OPTIONAL) ----------------------------------------
# LIFEOS_SCHEDULER_ENABLED=true
# CORS is a browser-functionality enabler, NOT a security boundary (single-user
# localhost no-auth). JSON list of allowed origins.
# LIFEOS_CORS_ORIGINS=["http://localhost:3000","http://localhost:3010"]
